    "scheduled_tasks": [
        {
            "time": "09:00",
            "narration": "Good morning sir, here is your daily briefing.",
            "macro": "briefing"
        },
        {
            "time": "23:00",
            "narration": "Wrapping up sir, doing a system save.",
            "macro": "shutdown"
        }
